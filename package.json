{
  "name": "autopsia-rn",
  "version": "0.3.0",
  "description": "Auditor de Clean Architecture para proyectos React Native / TypeScript. ESLint te dice si tu código está bien escrito; Autopsia te dice si tu arquitectura está bien construida.",
  "bin": {
    "autopsia": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "README.es.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanBenito12/Autopsia.git"
  },
  "bugs": {
    "url": "https://github.com/SanBenito12/Autopsia/issues"
  },
  "homepage": "https://github.com/SanBenito12/Autopsia#readme",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test",
    "scan:fixture": "tsx src/index.ts scan fixtures/sample-app --config fixtures/sample-app/autopsia.config.json",
    "scan:alias": "tsx src/index.ts scan fixtures/alias-app --config fixtures/alias-app/autopsia.config.json",
    "demo:html": "tsx src/index.ts scan fixtures/sample-app --config fixtures/sample-app/autopsia.config.json --html demo/report.html"
  },
  "keywords": [
    "clean-architecture",
    "react-native",
    "static-analysis",
    "architecture",
    "lint",
    "ast"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
